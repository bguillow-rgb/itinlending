# Copy to .env and fill in. All vars are PUBLIC_ because they're baked into the
# static HTML at build time (no server runtime on GitHub Pages). For GitHub
# Pages, build locally with these set, then commit /docs.

# Google Analytics 4 Measurement ID, e.g. G-XXXXXXXXXX
PUBLIC_GA4_ID=

# Google Search Console HTML-tag verification value (content of the meta tag)
PUBLIC_GSC_VERIFICATION=

# IndexNow key (also commit the matching <key>.txt at the site root)
PUBLIC_INDEXNOW_KEY=

# Google AdSense publisher ID, e.g. ca-pub-0000000000000000
PUBLIC_ADSENSE_ID=

# AdSense ad-unit slot IDs (numeric, from the AdSense dashboard). Each is
# optional — an empty slot renders nothing. Strategy: AdSense runs on
# research-intent ARTICLES (top = above fold, end = after body); MONEY pages
# get one unit below the FAQ so it only catches non-converters.
PUBLIC_ADSENSE_SLOT_ARTICLE_TOP=
PUBLIC_ADSENSE_SLOT_ARTICLE_END=
PUBLIC_ADSENSE_SLOT_MONEY_FOOTER=
# Thank-you page (post lead submit) — pure ad real estate, runs at full density.
PUBLIC_ADSENSE_SLOT_THANKYOU=

# Lead form POST endpoint (Formspree / Web3Forms / Basin), e.g.
# https://formspree.io/f/xxxxxxx
PUBLIC_LEAD_ENDPOINT=

# Optional: global off-site affiliate "apply" URL (Commission Junction deep
# link). When set, InlineCTA buttons route here with rel="sponsored nofollow".
# Used as the fallback when a product-specific URL below isn't set.
PUBLIC_AFFILIATE_APPLY_URL=

# Per-product affiliate deep links. Each money page's CTA routes to its own
# advertiser for max relevance/EPC; empty slots fall back per AFFILIATE_FALLBACKS
# (see consts.ts) then to the global URL above. Networks to join first: Impact +
# FlexOffers (then CommissionSoup + credit.com for OpenSky/Mission Lane).
#   Suggested fills (2026 research — verify ITIN acceptance + payout in-network):
# MORTGAGE  : no affiliate program exists for ITIN mortgages — leave blank;
#             falls back to LOANS. Monetize via direct per-funded referral deals.
PUBLIC_AFFILIATE_URL_MORTGAGE=
# AUTO      : no clean ITIN auto affiliate (Lendbuzz is B2B-only) — leave blank;
#             falls back to PERSONAL then LOANS. Filler: Upstart auto (Impact).
PUBLIC_AFFILIATE_URL_AUTO=
# CREDIT_CARDS: OpenSky Secured Visa ($25/funded, credit.com — genuinely ITIN);
#             alt Mission Lane Visa (CommissionSoup).
PUBLIC_AFFILIATE_URL_CREDIT_CARDS=
# PERSONAL  : Upstart personal loan (Impact, 1%); alt MoneyLion/Fiona marketplace.
PUBLIC_AFFILIATE_URL_PERSONAL=
# BUSINESS  : Lendio direct ($25/lead, 90-day); alt Sunwise Capital (Impact, $750/funded).
PUBLIC_AFFILIATE_URL_BUSINESS=
# LOANS (global hub + fallback target): Self credit-builder ($12, FlexOffers) or
#             Credit Strong ($41 CPA); Lendio marketplace as broad filler.
PUBLIC_AFFILIATE_URL_LOANS=
