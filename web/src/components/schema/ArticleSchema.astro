---
import { SITE } from '../../consts';
import { getLangFromUrl, localeFor } from '../../i18n/ui';

// Article schema with Speakable on the Quick Answer block (#quick-answer).
interface Props {
  title: string;
  description: string;
  url: string;
  publishedAt: Date;
  updatedAt?: Date;
  author: string;
}

const { title, description, url, publishedAt, updatedAt, author } = Astro.props;

const lang = getLangFromUrl(Astro.url);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  url,
  inLanguage: localeFor(lang),
  datePublished: publishedAt.toISOString(),
  dateModified: (updatedAt ?? publishedAt).toISOString(),
  author: { '@type': 'Organization', name: author, url: `${SITE.url}/about`, parentOrganization: { '@id': `${SITE.url}/#organization` } },
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    legalName: SITE.publisher.name,
    url: SITE.url,
    logo: { '@type': 'ImageObject', url: `${SITE.url}/icon-512.png` },
  },
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['#quick-answer'],
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
};
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
