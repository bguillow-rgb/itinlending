---
import { SITE } from '../../consts';
import { getLangFromUrl, localeFor } from '../../i18n/ui';

const lang = getLangFromUrl(Astro.url);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: `About \u2014 ${SITE.name}`,
  url: `${SITE.url}${lang === 'es' ? '/es' : ''}/about`,
  inLanguage: localeFor(lang),
  mainEntity: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
  },
};
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
