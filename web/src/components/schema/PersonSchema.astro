---
import { SITE } from '../../consts';
import { getLangFromUrl } from '../../i18n/ui';

// Person entity for the named editor — the E-E-A-T author anchor. Emitted on the
// /about page; the Article schema's `author` references the same @id so every
// article ties back to a single, described person. The @id is locale-independent
// so EN and ES pages resolve to one entity.
const lang = getLangFromUrl(Astro.url);
const isEs = lang === 'es';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${SITE.url}/#editor`,
  name: SITE.editorial.name,
  jobTitle: SITE.editorial.role,
  description: isEs ? SITE.editorial.bioEs : SITE.editorial.bio,
  url: `${SITE.url}${isEs ? '/es' : ''}/about`,
  knowsLanguage: ['en', 'es'],
  knowsAbout: [
    'ITIN loans',
    'ITIN mortgages',
    'credit for ITIN holders',
    'personal finance for immigrants',
  ],
  worksFor: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
  },
};
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
