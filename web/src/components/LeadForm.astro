---
import { SITE } from '../consts';
import { getLangFromUrl, useTranslations, localizedHref } from '../i18n/ui';

// US states + DC for the state dropdown (cleaner lead data than a free-text box).
const US_STATES = [
  'Alabama', 'Alaska', 'Arizona', 'Arkansas', 'California', 'Colorado', 'Connecticut',
  'Delaware', 'District of Columbia', 'Florida', 'Georgia', 'Hawaii', 'Idaho', 'Illinois',
  'Indiana', 'Iowa', 'Kansas', 'Kentucky', 'Louisiana', 'Maine', 'Maryland', 'Massachusetts',
  'Michigan', 'Minnesota', 'Mississippi', 'Missouri', 'Montana', 'Nebraska', 'Nevada',
  'New Hampshire', 'New Jersey', 'New Mexico', 'New York', 'North Carolina', 'North Dakota',
  'Ohio', 'Oklahoma', 'Oregon', 'Pennsylvania', 'Rhode Island', 'South Carolina',
  'South Dakota', 'Tennessee', 'Texas', 'Utah', 'Vermont', 'Virginia', 'Washington',
  'West Virginia', 'Wisconsin', 'Wyoming',
];

// Lead-capture form. Always renders as a real form (the primary CTA). It POSTs
// to a static-friendly handler (Formspree/Web3Forms/Basin) set via
// PUBLIC_LEAD_ENDPOINT. Leads route the instant that env var is set; until
// then the form renders fully and submits no-op to the same page.
interface Props {
  heading?: string;
  compact?: boolean;
}
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { heading = t('form.heading'), compact = false } = Astro.props;
const endpoint = SITE.monetize.leadFormEndpoint;
const web3formsKey = SITE.monetize.web3formsKey;
const thankYouUrl = localizedHref('/thank-you', lang);
const errorMsg =
  lang === 'es'
    ? 'No pudimos enviar tu solicitud. Inténtalo de nuevo.'
    : "We couldn't send your request. Please try again.";

const loanOptions =
  lang === 'es'
    ? ['Hipoteca / Casa', 'Préstamo de auto', 'Préstamo personal', 'Préstamo de negocio', 'Tarjeta de crédito', 'Aún no estoy seguro']
    : ['Mortgage / Home loan', 'Auto loan', 'Personal loan', 'Business loan', 'Credit card', 'Not sure yet'];

// Qualifying fields (full form only), these turn a name+phone lead into a
// lender-ready, sellable lead. amount/score/income/ITIN-status always show;
// time-in-business and down-payment reveal conditionally off the loan-type
// select (see the inline script). Kept as dropdowns for clean, comparable data.
const amountOptions =
  lang === 'es'
    ? ['Menos de $5,000', '$5,000-$10,000', '$10,000-$25,000', 'Más de $25,000']
    : ['Under $5,000', '$5,000-$10,000', '$10,000-$25,000', '$25,000+'];
const scoreOptions =
  lang === 'es'
    ? ['Menos de 580', '580-620', '620-680', '680+', 'No estoy seguro']
    : ['Under 580', '580-620', '620-680', '680+', 'Not sure'];
const incomeOptions =
  lang === 'es'
    ? ['Menos de $2,000', '$2,000-$4,000', '$4,000-$6,000', 'Más de $6,000']
    : ['Under $2,000', '$2,000-$4,000', '$4,000-$6,000', '$6,000+'];
const itinOptions =
  lang === 'es'
    ? ['Solo ITIN', 'ITIN + Seguro Social']
    : ['ITIN only', 'ITIN + SSN'];
const tibOptions =
  lang === 'es'
    ? ['Aún no abro', 'Menos de 1 año', '1-2 años', 'Más de 2 años']
    : ['Not open yet', 'Less than 1 year', '1-2 years', '2+ years'];
const downOptions =
  lang === 'es'
    ? ['Menos del 5%', '5-10%', '10-20%', 'Más del 20%']
    : ['Under 5%', '5-10%', '10-20%', '20%+'];
// Homeownership + buy-timeframe. Shown on EVERY form (incl. the compact hero form)
// because home-buying intent drives our FHA-for-ITIN (3.5% down) partner program.
// The timeframe question reveals only when "No — I want to buy" is chosen (index 1).
const homeOptions =
  lang === 'es'
    ? ['Soy dueño de una casa', 'No — quiero comprar una casa', 'No — no busco comprar']
    : ['I own a home', 'No — I want to buy a home', 'No — not looking to buy'];
const timeframeOptions =
  lang === 'es'
    ? ['Lo antes posible', '3–6 meses', '6–12 meses']
    : ['As soon as possible', '3–6 months', '6–12 months'];
---
<div class="form-card">
  <h3 class="mt-0">{heading}</h3>
  <p class="form-note" style="margin-bottom:18px">{t('form.note')}</p>

  <form class="lead-form" action={endpoint || undefined} method="POST" data-leadform data-error={errorMsg} data-redirect={thankYouUrl}>
    {web3formsKey && <input type="hidden" name="access_key" value={web3formsKey} />}
    <input type="hidden" name="subject" value="New ITIN lending lead" />
    <input type="hidden" name="from_name" value={SITE.name} />
    {/* Honeypot, bots tick this, humans don't (Web3Forms spam filter). */}
    <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" style="display:none" aria-hidden="true" />
    {/* Traffic-source attribution. Empty at build; filled client-side on load from
        document.referrer, the landing URL, and any utm_* params so every lead
        self-reports where it came from (see the inline script below). */}
    <input type="hidden" name="source_referrer" data-src="referrer" />
    <input type="hidden" name="landing_page" data-src="landing" />
    <input type="hidden" name="utm_source" data-src="utm_source" />
    <input type="hidden" name="utm_medium" data-src="utm_medium" />
    <input type="hidden" name="utm_campaign" data-src="utm_campaign" />
    <input type="hidden" name="utm_term" data-src="utm_term" />
    <input type="hidden" name="utm_content" data-src="utm_content" />
    {/* Certified-consent tokens. Empty until the TrustedForm / Jornaya scripts
        are added; the delivery layer refuses to send a lead to any partner that
        requires a cert while these are blank, so wiring them now is forward-safe. */}
    <input type="hidden" name="xxTrustedFormCertUrl" id="xxTrustedFormCertUrl" />
    <input type="hidden" name="universal_leadid" id="leadid_token" />

    <div class="field-row">
      <div class="field">
        <label for="first_name">{t('form.firstname')}</label>
        <input id="first_name" name="first_name" type="text" required autocomplete="given-name" placeholder={t('form.firstname.ph')} />
      </div>
      <div class="field">
        <label for="last_name">{t('form.lastname')}</label>
        <input id="last_name" name="last_name" type="text" required autocomplete="family-name" placeholder={t('form.lastname.ph')} />
      </div>
    </div>

    <div class="field-row">
      <div class="field">
        <label for="phone">{t('form.phone')}</label>
        <input id="phone" name="phone" type="tel" required autocomplete="tel" inputmode="numeric" maxlength="12" pattern="[0-9]{3}-[0-9]{3}-[0-9]{4}" title={t('form.phone.title')} placeholder={t('form.phone.ph')} data-phone />
      </div>
      <div class="field">
        <label for="email">{t('form.email')}</label>
        <input id="email" name="email" type="email" required autocomplete="email" placeholder={t('form.email.ph')} />
      </div>
    </div>

    {/* loanType + itin_status are the two routing keys the delivery router needs
        on EVERY lead (product x id-type), so both are required and both render on
        the compact form too, not just /apply. NOTE: do not put the string "SSN"
        into the ITIN-only option text — partners.ts::idTypeOf() tests for "ssn"
        first, so an option like "ITIN only (no SSN)" would misclassify the lead
        as ITIN+SSN. Change the label, never the option values. */}
    <div class="field-row">
      <div class="field">
        <label for="loanType">{t('form.need')}</label>
        <select id="loanType" name="loanType" required data-intent>
          <option value="">{t('form.need.select')}</option>
          {loanOptions.map((o) => <option>{o}</option>)}
        </select>
      </div>
      <div class="field">
        <label for="itin_status">{t('form.itin')}</label>
        <select id="itin_status" name="itin_status" required>
          <option value="">{t('form.select')}</option>
          {itinOptions.map((o) => <option>{o}</option>)}
        </select>
        <p class="field-help">{t('form.itin.help')}</p>
      </div>
    </div>

    <div class="field-row">
      <div class="field">
        <label for="state">{t('form.state')}</label>
        <select id="state" name="state" required autocomplete="address-level1">
          <option value="">{t('form.state.select')}</option>
          {US_STATES.map((s) => <option>{s}</option>)}
        </select>
        <p class="field-help">{t('form.state.help')}</p>
      </div>
      <div class="field">
        <label for="zip">{t('form.zip')}</label>
        <input id="zip" name="zip" type="text" autocomplete="postal-code" inputmode="numeric" maxlength="5" pattern="[0-9]{5}" title={t('form.zip.title')} placeholder={t('form.zip.ph')} data-zip />
      </div>
    </div>

    <div class="field-row">
      <div class="field">
        <label for="home_status">{t('form.home')}</label>
        <select id="home_status" name="home_status" data-home>
          <option value="">{t('form.home.select')}</option>
          {homeOptions.map((o) => <option>{o}</option>)}
        </select>
      </div>
      <div class="field" data-when-home="buying" hidden>
        <label for="buy_timeframe">{t('form.timeframe')}</label>
        <select id="buy_timeframe" name="buy_timeframe">
          <option value="">{t('form.select')}</option>
          {timeframeOptions.map((o) => <option>{o}</option>)}
        </select>
      </div>
    </div>

    {!compact && (
      <div class="qualify-block">
        <p class="form-subhead">{t('form.qualify.heading')}</p>
        <p class="form-note" style="margin:-6px 0 12px">{t('form.qualify.note')}</p>
        <div class="field-row">
          <div class="field">
            <label for="amount">{t('form.amount')}</label>
            <select id="amount" name="amount">
              <option value="">{t('form.select')}</option>
              {amountOptions.map((o) => <option>{o}</option>)}
            </select>
          </div>
          <div class="field">
            <label for="score">{t('form.score')}</label>
            <select id="score" name="score">
              <option value="">{t('form.select')}</option>
              {scoreOptions.map((o) => <option>{o}</option>)}
            </select>
          </div>
        </div>
        {/* itin_status used to live here (optional, /apply only). It moved up next
            to loanType and is now required on every form: ~47% of leads were
            arriving without it, and it is the routing key that decides which
            partners can even accept the lead. */}
        <div class="field">
          <label for="income">{t('form.income')}</label>
          <select id="income" name="income">
            <option value="">{t('form.select')}</option>
            {incomeOptions.map((o) => <option>{o}</option>)}
          </select>
        </div>
        <div class="field" data-when="business" hidden>
          <label for="time_in_business">{t('form.tib')}</label>
          <select id="time_in_business" name="time_in_business">
            <option value="">{t('form.select')}</option>
            {tibOptions.map((o) => <option>{o}</option>)}
          </select>
        </div>
        <div class="field" data-when="mortgage" hidden>
          <label for="down_payment">{t('form.down')}</label>
          <select id="down_payment" name="down_payment">
            <option value="">{t('form.select')}</option>
            {downOptions.map((o) => <option>{o}</option>)}
          </select>
        </div>
        <div class="field">
          <label for="notes">{t('form.notes')}</label>
          <textarea id="notes" name="notes" rows="3"></textarea>
        </div>
      </div>
    )}

    {/* TCPA express written consent. Unchecked, required. Names the recipients
        (this site + the linked partner list), authorizes autodialed/prerecorded
        calls + texts, and states consent is not a condition of purchase. The
        checked state + timestamp + TrustedForm cert are the paper trail. */}
    <label class="consent-check" for="tcpa_consent">
      <input type="checkbox" id="tcpa_consent" name="tcpa_consent" value="yes" required data-consent />
      <span>
        {t('form.consent.agree')}
        <a href={localizedHref('/privacy', lang)}>{t('form.privacy')}</a>,
        <a href={localizedHref('/disclosure', lang)}>{t('form.disclosure')}</a>, {t('form.and')}
        <a href={localizedHref('/terms', lang)}>{t('form.terms')}</a>{t('form.consent.tcpaLead')} {SITE.name} {t('form.consent.tcpaAnd')}
        <a href={localizedHref('/partners', lang)}>{t('form.consent.partners')}</a> {t('form.consent.tcpaBody')}
      </span>
    </label>

    <button type="submit" class="btn btn-primary btn-lg btn-block" data-submit data-label={t('form.submit')} data-busy={t('form.submitting')}>
      {t('form.submit')}
    </button>
  </form>
</div>

<style>
  .consent-check {
    display: flex; gap: 9px; align-items: flex-start;
    margin: 4px 0 14px; cursor: pointer;
    font-size: .8rem; line-height: 1.45; color: var(--text-muted, #64748b);
  }
  .consent-check input { margin-top: 2px; flex: 0 0 auto; width: 16px; height: 16px; cursor: pointer; }
  .consent-check a { color: inherit; text-decoration: underline; }
</style>

{SITE.monetize.trustedFormEnabled && (
  <script is:inline>
    (function () {
      var tf = document.createElement('script');
      tf.type = 'text/javascript'; tf.async = true;
      tf.src = 'https://api.trustedform.com/trustedform.js?field=xxTrustedFormCertUrl&ping_field=xxTrustedFormPingUrl&l=' + new Date().getTime() + Math.random();
      var s = document.getElementsByTagName('script')[0];
      s.parentNode.insertBefore(tf, s);
    })();
  </script>
)}

<script is:inline>
  (function () {
    // Auto-format phone inputs as 555-123-4567 while typing.
    document.querySelectorAll('input[data-phone]').forEach(function (input) {
      input.addEventListener('input', function () {
        var d = input.value.replace(/\D/g, '').slice(0, 10);
        if (d.length > 6) input.value = d.slice(0, 3) + '-' + d.slice(3, 6) + '-' + d.slice(6);
        else if (d.length > 3) input.value = d.slice(0, 3) + '-' + d.slice(3);
        else input.value = d;
      });
    });

    // Keep ZIP to 5 digits (buyers reject non-numeric postal codes).
    document.querySelectorAll('input[data-zip]').forEach(function (input) {
      input.addEventListener('input', function () {
        input.value = input.value.replace(/\D/g, '').slice(0, 5);
      });
    });

    // Conditional qualifier reveal: show time-in-business for "Business loan"
    // and down-payment for "Mortgage / Home loan", keyed off the intent select's
    // option order (1 = mortgage, 4 = business, fixed EN/ES).
    document.querySelectorAll('select[data-intent]').forEach(function (sel) {
      var form = sel.closest('form');
      if (!form) return;
      var mort = form.querySelector('[data-when="mortgage"]');
      var biz = form.querySelector('[data-when="business"]');
      if (!mort && !biz) return;
      function sync() {
        var i = sel.selectedIndex;
        if (mort) mort.hidden = i !== 1;
        if (biz) biz.hidden = i !== 4;
      }
      sel.addEventListener('change', sync);
      sync();
    });

    // Homeownership reveal: show the buy-timeframe question only when the user
    // picks "No — I want to buy a home" (option index 2, fixed EN/ES). No home /
    // owns a home / not looking → timeframe stays hidden and unsubmitted.
    document.querySelectorAll('select[data-home]').forEach(function (sel) {
      var form = sel.closest('form');
      if (!form) return;
      var tf = form.querySelector('[data-when-home="buying"]');
      if (!tf) return;
      function syncHome() { tf.hidden = sel.selectedIndex !== 2; }
      sel.addEventListener('change', syncHome);
      syncHome();
    });

    // Traffic-source capture: populate the hidden attribution fields on load so
    // the lead payload carries its own origin (referrer + landing page + utm_*).
    // First-touch utm_* is persisted in sessionStorage so a multi-page visit
    // still attributes to the entry source rather than the last internal hop.
    (function () {
      try {
        var params = new URLSearchParams(location.search);
        var store = {};
        try { store = JSON.parse(sessionStorage.getItem('itin_src') || '{}'); } catch (e) {}
        ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content'].forEach(function (k) {
          var v = params.get(k);
          if (v && !store[k]) store[k] = v;
        });
        if (!store.referrer) {
          var ref = document.referrer || '';
          // Ignore same-host referrers so internal navigation doesn't overwrite
          // the true external origin.
          if (!ref || ref.indexOf(location.origin) !== 0) store.referrer = ref;
        }
        if (!store.landing) store.landing = location.href;
        try { sessionStorage.setItem('itin_src', JSON.stringify(store)); } catch (e) {}
        document.querySelectorAll('[data-src]').forEach(function (el) {
          var key = el.getAttribute('data-src');
          var map = { referrer: store.referrer, landing: store.landing };
          el.value = (key in map ? map[key] : store[key]) || '';
        });
      } catch (e) {}
    })();

    var forms = document.querySelectorAll('form[data-leadform]');
    forms.forEach(function (form) {
      form.addEventListener('submit', function (e) {
        // No endpoint configured → let the native (no-op) submit happen.
        if (!form.getAttribute('action')) return;
        e.preventDefault();
        if (!form.checkValidity()) { form.reportValidity(); return; }
        var btn = form.querySelector('[data-submit]');
        if (btn) {
          btn.setAttribute('aria-busy', 'true');
          btn.textContent = btn.getAttribute('data-busy');
        }
        fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (!data.success) throw new Error(data.message || 'error');
            // Map the chosen loan type to its money-page slug (by option order,
            // which is fixed EN/ES) so the thank-you page can show the matching
            // affiliate CTA. Index 0 is the placeholder; '' = no match / "Not sure".
            var slugs = ['', 'itin-mortgage', 'itin-auto-loan', 'itin-personal-loans', 'itin-business-loans', 'itin-credit-cards', ''];
            var sel = form.querySelector('#loanType');
            var slug = sel ? (slugs[sel.selectedIndex] || '') : '';
            var redirect = form.getAttribute('data-redirect') || '/';
            if (slug) redirect += (redirect.indexOf('?') > -1 ? '&' : '?') + 'for=' + encodeURIComponent(slug);
            window.location.href = redirect;
          })
          .catch(function () {
            if (btn) {
              btn.removeAttribute('aria-busy');
              btn.textContent = btn.getAttribute('data-label');
            }
            window.alert(form.getAttribute('data-error'));
          });
      });
    });
  })();
</script>
