---
import { SITE } from '../consts';
import { getLangFromUrl, useTranslations, localizedHref } from '../i18n/ui';

// US states + DC for the state dropdown (cleaner lead data than a free-text box).
const US_STATES = [
  'Alabama', 'Alaska', 'Arizona', 'Arkansas', 'California', 'Colorado', 'Connecticut',
  'Delaware', 'District of Columbia', 'Florida', 'Georgia', 'Hawaii', 'Idaho', 'Illinois',
  'Indiana', 'Iowa', 'Kansas', 'Kentucky', 'Louisiana', 'Maine', 'Maryland', 'Massachusetts',
  'Michigan', 'Minnesota', 'Mississippi', 'Missouri', 'Montana', 'Nebraska', 'Nevada',
  'New Hampshire', 'New Jersey', 'New Mexico', 'New York', 'North Carolina', 'North Dakota',
  'Ohio', 'Oklahoma', 'Oregon', 'Pennsylvania', 'Rhode Island', 'South Carolina',
  'South Dakota', 'Tennessee', 'Texas', 'Utah', 'Vermont', 'Virginia', 'Washington',
  'West Virginia', 'Wisconsin', 'Wyoming',
];

// Lead-capture form. Always renders as a real form (the primary CTA). It POSTs
// to a static-friendly handler (Formspree/Web3Forms/Basin) set via
// PUBLIC_LEAD_ENDPOINT. Leads route the instant that env var is set; until
// then the form renders fully and submits no-op to the same page.
interface Props {
  heading?: string;
  compact?: boolean;
}
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { heading = t('form.heading'), compact = false } = Astro.props;
const endpoint = SITE.monetize.leadFormEndpoint;
const web3formsKey = SITE.monetize.web3formsKey;
const thankYouUrl = localizedHref('/thank-you', lang);
const errorMsg =
  lang === 'es'
    ? 'No pudimos enviar tu solicitud. Inténtalo de nuevo.'
    : "We couldn't send your request. Please try again.";

const loanOptions =
  lang === 'es'
    ? ['Hipoteca / Casa', 'Préstamo de auto', 'Préstamo personal', 'Préstamo de negocio', 'Tarjeta de crédito', 'Aún no estoy seguro']
    : ['Mortgage / Home loan', 'Auto loan', 'Personal loan', 'Business loan', 'Credit card', 'Not sure yet'];
---
<div class="form-card">
  <h3 class="mt-0">{heading}</h3>
  <p class="form-note" style="margin-bottom:18px">{t('form.note')}</p>

  <form class="lead-form" action={endpoint || undefined} method="POST" data-leadform data-error={errorMsg} data-redirect={thankYouUrl}>
    {web3formsKey && <input type="hidden" name="access_key" value={web3formsKey} />}
    <input type="hidden" name="subject" value="New ITIN lending lead" />
    <input type="hidden" name="from_name" value={SITE.name} />
    {/* Honeypot — bots tick this, humans don't (Web3Forms spam filter). */}
    <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" style="display:none" aria-hidden="true" />

    <div class="field-row">
      <div class="field">
        <label for="name">{t('form.name')}</label>
        <input id="name" name="name" type="text" required autocomplete="name" placeholder={t('form.name.ph')} />
      </div>
      <div class="field">
        <label for="phone">{t('form.phone')}</label>
        <input id="phone" name="phone" type="tel" required autocomplete="tel" inputmode="numeric" maxlength="12" pattern="[0-9]{3}-[0-9]{3}-[0-9]{4}" title={t('form.phone.title')} placeholder={t('form.phone.ph')} data-phone />
      </div>
    </div>

    <div class="field">
      <label for="email">{t('form.email')}</label>
      <input id="email" name="email" type="email" required autocomplete="email" placeholder={t('form.email.ph')} />
    </div>

    <div class="field-row">
      <div class="field">
        <label for="loanType">{t('form.need')}</label>
        <select id="loanType" name="loanType" required>
          <option value="">{t('form.need.select')}</option>
          {loanOptions.map((o) => <option>{o}</option>)}
        </select>
      </div>
      <div class="field">
        <label for="state">{t('form.state')}</label>
        <select id="state" name="state" required autocomplete="address-level1">
          <option value="">{t('form.state.select')}</option>
          {US_STATES.map((s) => <option>{s}</option>)}
        </select>
        <p class="field-help">{t('form.state.help')}</p>
      </div>
    </div>

    {!compact && (
      <div class="field">
        <label for="notes">{t('form.notes')}</label>
        <textarea id="notes" name="notes" rows="3"></textarea>
      </div>
    )}

    <button type="submit" class="btn btn-primary btn-lg btn-block" data-submit data-label={t('form.submit')} data-busy={t('form.submitting')}>
      {t('form.submit')}
    </button>
    <p class="form-note">
      {t('form.consent.pre')} {SITE.name} {t('form.consent.post')}
      <a href={localizedHref('/privacy', lang)}>{t('form.privacy')}</a> {t('form.and')}
      <a href={localizedHref('/disclosure', lang)}>{t('form.disclosure')}</a>.
    </p>
  </form>
</div>

<script is:inline>
  (function () {
    // Auto-format phone inputs as 555-123-4567 while typing.
    document.querySelectorAll('input[data-phone]').forEach(function (input) {
      input.addEventListener('input', function () {
        var d = input.value.replace(/\D/g, '').slice(0, 10);
        if (d.length > 6) input.value = d.slice(0, 3) + '-' + d.slice(3, 6) + '-' + d.slice(6);
        else if (d.length > 3) input.value = d.slice(0, 3) + '-' + d.slice(3);
        else input.value = d;
      });
    });

    var forms = document.querySelectorAll('form[data-leadform]');
    forms.forEach(function (form) {
      form.addEventListener('submit', function (e) {
        // No endpoint configured → let the native (no-op) submit happen.
        if (!form.getAttribute('action')) return;
        e.preventDefault();
        if (!form.checkValidity()) { form.reportValidity(); return; }
        var btn = form.querySelector('[data-submit]');
        if (btn) {
          btn.setAttribute('aria-busy', 'true');
          btn.textContent = btn.getAttribute('data-busy');
        }
        fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (!data.success) throw new Error(data.message || 'error');
            // Map the chosen loan type to its money-page slug (by option order,
            // which is fixed EN/ES) so the thank-you page can show the matching
            // affiliate CTA. Index 0 is the placeholder; '' = no match / "Not sure".
            var slugs = ['', 'itin-mortgage', 'itin-auto-loan', 'itin-personal-loans', 'itin-business-loans', 'itin-credit-cards', ''];
            var sel = form.querySelector('#loanType');
            var slug = sel ? (slugs[sel.selectedIndex] || '') : '';
            var redirect = form.getAttribute('data-redirect') || '/';
            if (slug) redirect += (redirect.indexOf('?') > -1 ? '&' : '?') + 'for=' + encodeURIComponent(slug);
            window.location.href = redirect;
          })
          .catch(function () {
            if (btn) {
              btn.removeAttribute('aria-busy');
              btn.textContent = btn.getAttribute('data-label');
            }
            window.alert(form.getAttribute('data-error'));
          });
      });
    });
  })();
</script>
