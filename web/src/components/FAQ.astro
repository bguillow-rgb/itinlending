---
import FAQPageSchema from './schema/FAQPageSchema.astro';

interface Props {
  faqs: { q: string; a: string }[];
  heading?: string;
}

const { faqs, heading = 'Frequently Asked Questions' } = Astro.props;
---
{faqs.length > 0 && (
  <section class="faq">
    <h2>{heading}</h2>
    {faqs.map(({ q, a }) => (
      <div class="faq-item">
        <p class="faq-q">{q}</p>
        <p class="faq-a">{a}</p>
      </div>
    ))}
    <FAQPageSchema faqs={faqs} />
  </section>
)}
