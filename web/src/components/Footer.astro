---
import { SITE, PRODUCTS } from '../consts';
import { getLangFromUrl, useTranslations, localizedHref } from '../i18n/ui';
const year = new Date().getFullYear();
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isEs = lang === 'es';
const L = (href: string) => localizedHref(href, lang);

// Cross-links to our sister ITIN sites (editorial, same-network). A visitor who
// landed on the wrong site for their need — cards vs. loans vs. credit score —
// still ends up on one of ours. `network` is the two sites that are NOT this one.
const network = [
  {
    url: 'https://itinlending.net',
    label: 'ITIN Loans & Mortgages',
    labelEs: 'Préstamos e Hipotecas ITIN',
    desc: 'Auto, personal & business loans and mortgages with an ITIN',
    descEs: 'Préstamos de auto, personales y de negocio e hipotecas con ITIN',
  },
  {
    url: 'https://itincreditcard.com',
    label: 'ITIN Credit Cards',
    labelEs: 'Tarjetas de Crédito para ITIN',
    desc: 'Secured & unsecured cards that accept an ITIN',
    descEs: 'Tarjetas aseguradas y sin garantía que aceptan un ITIN',
  },
  {
    url: 'https://itincreditscore.com',
    label: 'ITIN Credit Score & Building',
    labelEs: 'Puntaje de Crédito con ITIN',
    desc: 'Check, build, and improve your credit with an ITIN',
    descEs: 'Consulta, construye y mejora tu crédito con un ITIN',
  },
].filter((n) => n.url !== SITE.url);

const resources = isEs
  ? [
      { label: 'Guía de Préstamos ITIN', href: '/itin-loans' },
      { label: 'Todas las Guías', href: '/articles' },
      { label: 'Ver si Califico', href: '/apply' },
      { label: 'Nosotros', href: '/about' },
      { label: 'Contacto', href: '/contact' },
    ]
  : [
      { label: 'ITIN Loans Guide', href: '/itin-loans' },
      { label: 'All Guides', href: '/articles' },
      { label: 'See If You Qualify', href: '/apply' },
      { label: 'About Us', href: '/about' },
      { label: 'Contact', href: '/contact' },
    ];

const legal = isEs
  ? [
      { label: 'Política de Privacidad', href: '/privacy' },
      { label: 'Términos de Uso', href: '/terms' },
      { label: 'Aviso para Anunciantes', href: '/disclosure' },
      { label: 'Política Editorial', href: '/editorial-policy' },
    ]
  : [
      { label: 'Privacy Policy', href: '/privacy' },
      { label: 'Terms of Use', href: '/terms' },
      { label: 'Advertiser Disclosure', href: '/disclosure' },
      { label: 'Editorial Policy', href: '/editorial-policy' },
    ];

const tagline = isEs ? SITE.taglineEs : SITE.tagline;
const loanTypesHeading = isEs ? 'Tipos de Préstamo' : 'Loan Types';
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <div class="footer-brand">{SITE.name}<span style="color:var(--accent)">.</span></div>
        <p>{tagline}.</p>
        <h4>{t('footer.trust')}</h4>
        <ul class="footer-trust">
          <li><span class="tick">&#10003;</span> {t('footer.trust.independent')}</li>
          <li><span class="tick">&#10003;</span> {t('footer.trust.free')}</li>
          <li><span class="tick">&#10003;</span> {t('footer.trust.privacy')}</li>
        </ul>
        <p style="margin-top:14px"><a href={`mailto:${SITE.supportEmail}`}>Contact</a></p>
      </div>
      <div>
        <h4>{loanTypesHeading}</h4>
        <ul class="footer-links">
          {PRODUCTS.map((p) => (
            <li><a href={L(`/${p.slug}`)}>{isEs ? p.labelEs : p.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4>{t('footer.resources')}</h4>
        <ul class="footer-links">
          {resources.map((r) => <li><a href={L(r.href)}>{r.label}</a></li>)}
        </ul>
      </div>
      <div>
        <h4>{t('footer.legal')}</h4>
        <ul class="footer-links">
          {legal.map((r) => <li><a href={L(r.href)}>{r.label}</a></li>)}
        </ul>
      </div>
    </div>
    <div class="footer-network">
      <h4>{isEs ? 'Más Recursos para Personas con ITIN' : 'More ITIN Resources'}</h4>
      <ul>
        {network.map((n) => (
          <li>
            <a href={n.url}>{isEs ? n.labelEs : n.label}</a>
            <span>{isEs ? n.descEs : n.desc}</span>
          </li>
        ))}
      </ul>
    </div>
    <div class="footer-disclaimer">
      {isEs ? (
        <p>
          &copy; {year} {SITE.legalName}, operado por {SITE.publisher.name}. Todos los derechos reservados.
          {SITE.name} es un recurso independiente de información y referencia. No
          somos un banco, prestamista, bróker hipotecario ni asesor financiero, y
          no tomamos decisiones de crédito ni originamos préstamos. La información
          de este sitio tiene fines educativos generales y no constituye asesoría
          financiera, legal ni fiscal. Los productos, tasas y términos los ofrecen
          prestamistas externos y están sujetos a su aprobación y a la ley
          aplicable. Podemos recibir compensación cuando haces clic en ciertos
          enlaces o te conectamos con un prestamista, consulta nuestro
          <a href={L('/disclosure')}>Aviso para Anunciantes</a>.
        </p>
      ) : (
        <p>
          &copy; {year} {SITE.legalName}, operated by {SITE.publisher.name}. All rights reserved.
          {SITE.name} is an independent information and referral resource. We are
          not a bank, lender, mortgage broker, or financial advisor, and we do not
          make credit decisions or originate loans. Information on this site is for
          general educational purposes only and is not financial, legal, or tax
          advice. Loan products, rates, and terms are offered by third-party
          lenders and are subject to their approval, eligibility requirements, and
          applicable law. We may receive compensation when you click certain links
          or are matched with a lender, see our
          <a href={L('/disclosure')}>Advertiser Disclosure</a>.
        </p>
      )}
    </div>
  </div>
</footer>

<style>
  .footer-network {
    border-top: 1px solid var(--border);
    margin-top: 4px;
    padding-top: 22px;
  }
  .footer-network h4 { margin: 0 0 14px; }
  .footer-network ul {
    list-style: none; margin: 0; padding: 0;
    display: grid; gap: 14px;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }
  .footer-network li { line-height: 1.35; }
  .footer-network a { font-weight: 700; text-decoration: none; color: var(--text); }
  .footer-network a:hover { color: var(--primary); text-decoration: underline; }
  .footer-network span {
    display: block; margin-top: 3px;
    font-size: .85rem; color: var(--text-muted, #64748b);
  }
</style>
