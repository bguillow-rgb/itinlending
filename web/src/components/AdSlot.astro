---
import { SITE } from '../consts';

// Google AdSense in-article slot. Renders nothing unless an AdSense publisher
// ID is configured (PUBLIC_ADSENSE_ID) and we're in a production build, so the
// dev site and forks stay ad-free. Pass the ad unit slot ID once you create
// the unit in your AdSense dashboard.
interface Props {
  slot?: string;
}
const { slot = '' } = Astro.props;
const adsense = SITE.monetize.adsenseId;
const enableAds = import.meta.env.PROD && Boolean(adsense) && Boolean(slot);
---
{enableAds && (
  <div class="ad-slot">
    <span class="ad-label">Advertisement</span>
    <ins
      class="adsbygoogle"
      style="display:block"
      data-ad-client={adsense}
      data-ad-slot={slot}
      data-ad-format="auto"
      data-full-width-responsive="true"
    ></ins>
    <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </div>
)}
