---
import { SITE } from '../consts';
import { getLangFromUrl, altPath } from '../i18n/ui';
import OrganizationSchema from '../components/schema/OrganizationSchema.astro';
import WebSiteSchema from '../components/schema/WebSiteSchema.astro';
import Analytics from '../components/Analytics.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  // Canonical path on this site, e.g. '/about'. Empty on homepage.
  path?: string;
  noindex?: boolean;
  // Suppress global Organization + WebSite schema (articles emit their own
  // type-specific schema and we avoid duplication where needed).
  suppressGlobalSchema?: boolean;
  // Per-page social card path under /og (e.g. '/og/itin-mortgage.png').
  // Falls back to the generic brand card when omitted.
  ogImage?: string;
}

const lang = getLangFromUrl(Astro.url);
const isEs = lang === 'es';

const {
  title,
  description = isEs ? SITE.descriptionEs : SITE.description,
  noindex = false,
  suppressGlobalSchema = false,
  ogImage = '/og.png',
} = Astro.props;
const ogImageUrl = `${SITE.url}${ogImage}`;

// Canonical + hreflang derived from the actual URL so /es pages are correct.
const pathname =
  (Astro.url.pathname
    .replace(/index\.html$/, '')
    .replace(/\.html$/, '')
    .replace(/\/$/, '') || '/');
const abs = (p: string) => `${SITE.url}${p === '/' ? '' : p}`;
const canonical = abs(pathname);
const enHref = abs(altPath(pathname, 'en'));
const esHref = abs(altPath(pathname, 'es'));

const tagline = isEs ? SITE.taglineEs : SITE.tagline;
const fullTitle =
  title === SITE.name
    ? `${SITE.name} | ${tagline}`
    : `${title} | ${SITE.name}`;
---
<!doctype html>
<html lang={isEs ? 'es' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="es" href={esHref} />
    <link rel="alternate" hreflang="x-default" href={enHref} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.png" sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href="/icon-180.png" />
    <meta name="theme-color" content={SITE.theme.primary} />
    <link rel="alternate" type="application/rss+xml" title={`${SITE.name} | Guides`} href="/rss.xml" />

    {!suppressGlobalSchema && <OrganizationSchema />}
    {!suppressGlobalSchema && <WebSiteSchema />}

    <Analytics />
    <slot name="head" />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
