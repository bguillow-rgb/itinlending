---
import BaseLayout from './BaseLayout.astro';
import QuickAnswer from '../components/QuickAnswer.astro';
import FAQ from '../components/FAQ.astro';
import Disclosure from '../components/Disclosure.astro';
import InlineCTA from '../components/InlineCTA.astro';
import CreditKarmaAd from '../components/CreditKarmaAd.astro';
import RelatedLinks from '../components/RelatedLinks.astro';
import Icon from '../components/Icon.astro';
import BreadcrumbSchema from '../components/schema/BreadcrumbSchema.astro';
import ServiceSchema from '../components/schema/ServiceSchema.astro';
import { SITE, PRODUCTS, affiliateUrlFor } from '../consts';
import { getLangFromUrl, useTranslations, localizedHref, localeFor } from '../i18n/ui';

// Layout for product cluster / hub pages — the commercial-intent "money"
// pages (ITIN mortgage, auto loan, credit cards, etc.). Hero with lead form,
// editorial body slot, conversion CTA, FAQ + FAQPage schema, breadcrumb.
interface Props {
  title: string;
  h1: string;
  description: string;
  path: string;
  eyebrow?: string;
  lede: string;
  quickAnswer: string;
  faqs: { q: string; a: string }[];
  updated?: string;
  // Optional hero background photo (path under /img). Adds the dark-overlay
  // image treatment instead of the flat gradient.
  heroImage?: string;
  heroAlt?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isEs = lang === 'es';

const {
  title,
  h1,
  description,
  path,
  eyebrow = isEs ? 'Financiamiento con ITIN' : 'ITIN financing',
  lede,
  quickAnswer,
  faqs,
  updated = isEs ? '5 de junio de 2026' : 'June 5, 2026',
  heroImage,
  heroAlt = '',
} = Astro.props;

const fullUrl = `${SITE.url}${path}`;
const crumbs = [{ name: h1, url: fullUrl }];
const ogSlug = path.replace(/^\/(es\/)?/, '').replace(/^\//, '') || 'home';
// Per-product CJ deep link for this money page (falls back to global / /apply).
const affiliateUrl = affiliateUrlFor(path);

// Per-cluster hero identity: a distinct accent color + icon per page so each
// money page's above-the-fold reads as its own page, not the same blue hero.
// Icon + accent come from the matching PRODUCT — cycling the palette by the
// product's order maximizes color spread between sibling pages. Pages not in
// PRODUCTS fall back to a stable per-slug hash.
const ACCENTS = ['#11366B', '#0E7490', '#6D28D9', '#15803D', '#B45309', '#BE123C'];
const prodIndex = PRODUCTS.findIndex((p) => p.slug === ogSlug);
const heroIcon = prodIndex >= 0 ? PRODUCTS[prodIndex].icon : 'doc';
const accentKey =
  prodIndex >= 0
    ? prodIndex
    : [...ogSlug].reduce((h, c) => (h * 31 + c.charCodeAt(0)) >>> 0, 7);
const heroAccent = ACCENTS[accentKey % ACCENTS.length];
const loansLabel = isEs ? 'Préstamos ITIN' : 'ITIN Loans';
const updatedLabel = isEs ? 'Actualizado' : 'Updated';

// WebPage + Speakable: marks the Quick Answer block as the passage AI/voice
// engines should read aloud. ServiceSchema (FinancialService) can't legitimately
// host `speakable`, so the money page emits its own WebPage node for it.
const speakableSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': fullUrl,
  url: fullUrl,
  name: title,
  inLanguage: localeFor(lang),
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['#quick-answer'],
  },
};
---
<BaseLayout title={title} description={description} path={path} ogImage={`/og/${ogSlug}.png`}>
  <Fragment slot="head">
    <BreadcrumbSchema crumbs={crumbs} />
    <ServiceSchema name={h1} description={description} url={fullUrl} serviceType={eyebrow} />
    <script type="application/ld+json" set:html={JSON.stringify(speakableSchema)} />
  </Fragment>

  <section class={`hero hero--accent${heroImage ? ' hero--image' : ''}`} style={`--hero-accent:${heroAccent}`}>
    {heroImage && <img class="hero-bg" src={heroImage} alt={heroAlt} loading="eager" fetchpriority="high" decoding="async" />}
    <div class="container hero-grid">
      <div>
        <p class="crumbs"><a href={localizedHref('/', lang)}>{t('crumb.home')}</a> &rsaquo; <a href={localizedHref('/itin-loans', lang)}>{loansLabel}</a> &rsaquo; <span>{h1}</span></p>
        <div class="hero-badge"><Icon name={heroIcon} size={26} /></div>
        <span class="eyebrow">{eyebrow}</span>
        <h1>{h1}</h1>
        <p class="lede">{lede}</p>
        <div class="hero-cta">
          <a href={localizedHref('/apply', lang)} class="btn btn-primary btn-lg">{t('cta.qualify')}</a>
        </div>
        <p class="byline" style="margin-top:16px">{updatedLabel} {updated}</p>
      </div>
      <div>
        <CreditKarmaAd path={path} />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <Disclosure />
      <QuickAnswer text={quickAnswer} />
      <div class="article-body">
        <slot />
      </div>
      <InlineCTA affiliateUrl={affiliateUrl} />
      <RelatedLinks currentPath={path} />
      <FAQ faqs={faqs} />
      <!-- Money page: single Credit Karma ad below the fold (after FAQ), topic
           matched to the page, so it only catches visitors who didn't convert. -->
      <CreditKarmaAd path={path} inline={true} />
    </div>
  </section>
</BaseLayout>
