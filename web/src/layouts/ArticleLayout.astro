---
import BaseLayout from './BaseLayout.astro';
import QuickAnswer from '../components/QuickAnswer.astro';
import FAQ from '../components/FAQ.astro';
import Disclosure from '../components/Disclosure.astro';
import InlineCTA from '../components/InlineCTA.astro';
import RelatedLinks from '../components/RelatedLinks.astro';
import SourcesNote from '../components/SourcesNote.astro';
import CreditKarmaAd from '../components/CreditKarmaAd.astro';
import ArticleSchema from '../components/schema/ArticleSchema.astro';
import BreadcrumbSchema from '../components/schema/BreadcrumbSchema.astro';
import HowToSchema from '../components/schema/HowToSchema.astro';
import { SITE } from '../consts';

interface Props {
  title: string;
  description: string;
  path: string;
  publishedAt: Date;
  updatedAt?: Date;
  author: string;
  quickAnswer: string;
  faqs: { q: string; a: string }[];
  category?: string;
  // Breadcrumb section between Home and the article.
  section?: { name: string; url: string };
  // Optional ordered steps for genuinely step-based articles — emits HowTo
  // schema alongside Article schema when present.
  howToSteps?: { name: string; text: string }[];
}

const {
  title,
  description,
  path,
  publishedAt,
  updatedAt,
  author,
  quickAnswer,
  faqs,
  category = 'Guides',
  section,
  howToSteps = [],
} = Astro.props;

const fullUrl = `${SITE.url}${path}`;
const crumbs = [...(section ? [section] : []), { name: title, url: fullUrl }];
const ogSlug = path.replace(/^\/(es\/)?articles\//, '').replace(/^\//, '');

const formattedDate = (updatedAt ?? publishedAt).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Byline + bio for the article's assigned author. Falls back to the lead editor
// when the author isn't in the roster (older posts written before rotation).
const isEs = path.startsWith('/es/');
const byline = author || SITE.editorial.name;
const team = (SITE.editorial as any).team ?? [];
const bioMember =
  team.find((m: any) => m.name === byline) ||
  (byline === SITE.editorial.name ? SITE.editorial : null);
const bioText = bioMember ? (isEs ? bioMember.bioEs : bioMember.bio) : '';
const bioRole = bioMember?.role || '';
---
<BaseLayout title={title} description={description} path={path} ogImage={`/og/${ogSlug}.png`}>
  <Fragment slot="head">
    <ArticleSchema
      title={title}
      description={description}
      url={fullUrl}
      publishedAt={publishedAt}
      updatedAt={updatedAt}
      author={byline}
    />
    <BreadcrumbSchema crumbs={crumbs} />
    {howToSteps.length > 0 && (
      <HowToSchema title={title} description={description} url={fullUrl} steps={howToSteps} />
    )}
  </Fragment>

  <article class="container narrow" style="padding-top:18px;padding-bottom:24px">
    <p class="crumbs">
      <a href="/">Home</a> &rsaquo;
      {section && <><a href={section.url}>{section.name}</a> &rsaquo; </>}
      <span>{title}</span>
    </p>

    <span class="tag">{category}</span>
    <h1 style="margin-top:10px">{title}</h1>
    <p class="byline">
      By <a href="/about">{byline}</a>{bioRole && <> &middot; {bioRole}</>} &middot;
      {updatedAt ? 'Updated' : 'Published'} {formattedDate}
    </p>

    <Disclosure />
    <QuickAnswer text={quickAnswer} />

    <!-- Highest-visibility article slot: above the fold, after the Quick Answer.
         Credit Karma creative auto-matched to the article topic via its path. -->
    <CreditKarmaAd path={path} inline={true} />

    <div class="article-body">
      <slot />
    </div>

    <CreditKarmaAd path={path} inline={true} />
    <InlineCTA />
    <SourcesNote />
    {bioText && (
      <aside class="author-bio">
        <p class="author-bio-name">{byline}{bioRole && <span class="author-bio-role"> &middot; {bioRole}</span>}</p>
        <p class="author-bio-text">{bioText}</p>
        <p class="author-bio-link"><a href={isEs ? '/es/about' : '/about'}>{isEs ? 'Sobre nuestro equipo editorial' : 'About our editorial team'}</a></p>
      </aside>
    )}
    <RelatedLinks currentPath={path} heading="Related guides" />
    <FAQ faqs={faqs} />
  </article>
</BaseLayout>

<style>
  .author-bio {
    margin: 28px 0;
    padding: 18px 20px;
    border: 1px solid var(--border, #e2e6ee);
    border-radius: 12px;
    background: var(--surface-2, #f7f9fc);
  }
  .author-bio-name {
    margin: 0 0 6px;
    font-weight: 700;
  }
  .author-bio-role {
    font-weight: 400;
    color: var(--muted, #5a6473);
  }
  .author-bio-text {
    margin: 0 0 8px;
    font-size: 0.95rem;
    line-height: 1.55;
  }
  .author-bio-link {
    margin: 0;
    font-size: 0.9rem;
  }
</style>
