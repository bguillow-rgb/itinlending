---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CollectionPageSchema from '../../../components/schema/CollectionPageSchema.astro';
import { SITE } from '../../../consts';

const includeDrafts = import.meta.env.DEV;
const pub = ({ data }) => (includeDrafts ? true : data.published);
const en = await getCollection('articles', pub);
const es = await getCollection('articles-es', pub);
const esBySlug = new Map(es.map((e) => [e.slug, e]));
// One card per EN slug, preferring the es-419 translation's title/description
// when it exists (falls back to EN until backfill fills the gap).
const posts = en
  .map((entry) => esBySlug.get(entry.slug) ?? entry)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const title = 'Guías de Préstamos y Crédito con ITIN';
const description =
  'Guías en lenguaje claro sobre hipotecas, préstamos de auto, préstamos personales, préstamos de negocio, tarjetas de crédito con ITIN y cómo obtener un ITIN. Investigadas, precisas y actualizadas.';

const itemList = posts.map((p) => ({
  name: p.data.title,
  url: `${SITE.url}/es/articles/${p.slug}`,
}));
---
<BaseLayout title={title} description={description} path="/es/articles">
  <Fragment slot="head">
    <CollectionPageSchema
      name={title}
      description={description}
      url={`${SITE.url}/es/articles`}
      items={itemList}
    />
  </Fragment>
  <section class="section">
    <div class="container narrow">
      <span class="tag">Guías</span>
      <h1 style="margin-top:10px">Guías de préstamos y crédito con ITIN</h1>
      <p class="lede" style="color:var(--muted)">
        Todo lo que sabemos sobre pedir prestado y construir crédito con un ITIN,
        escrito para personas reales, no para banqueros.
      </p>

      {posts.length === 0 ? (
        <p>Pronto publicaremos nuevas guías. Mientras tanto,
          <a href="/es/itin-loans">comienza con nuestro resumen de préstamos con ITIN</a>.</p>
      ) : (
        <div class="post-list">
          {posts.map((post) => (
            <a class="post-card" href={`/es/articles/${post.slug}`}>
              <div>
                <span class="meta">{post.data.category}</span>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
              </div>
              <span class="tag">{post.data.tier}</span>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
