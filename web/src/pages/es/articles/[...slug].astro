---
import { getCollection, type CollectionEntry } from 'astro:content';
import ArticleLayout from '../../../layouts/ArticleLayout.astro';
import { SITE } from '../../../consts';

export async function getStaticPaths() {
  // Dev includes drafts for preview; production builds exclude them.
  const includeDrafts = import.meta.env.DEV;
  const pub = ({ data }: { data: { published: boolean } }) =>
    includeDrafts ? true : data.published;
  const en = await getCollection('articles', pub);
  const es = await getCollection('articles-es', pub);
  const esBySlug = new Map(es.map((e) => [e.slug, e]));
  // One ES page per EN slug. Use the es-419 translation when it exists; until
  // backfill fills a gap, fall back to the EN entry so the URL never 404s.
  return en.map((entry) => {
    const translated = esBySlug.get(entry.slug);
    return {
      params: { slug: entry.slug },
      props: { entry: translated ?? entry },
    };
  });
}

interface Props {
  entry: CollectionEntry<'articles'> | CollectionEntry<'articles-es'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;
const path = `/es/articles/${entry.slug}`;
---
<ArticleLayout
  title={data.title}
  description={data.description}
  path={path}
  publishedAt={data.publishedAt}
  updatedAt={data.updatedAt}
  author={data.author}
  quickAnswer={data.quickAnswer}
  faqs={data.faqs}
  category={data.category}
  howToSteps={data.howToSteps}
  section={{ name: 'Guías', url: `${SITE.url}/es/articles` }}
>
  <Content />

  {data.relatedSlugs.length > 0 && (
    <section>
      <h2>Guías relacionadas</h2>
      <ul class="lead-list">
        {data.relatedSlugs.map((slug) => (
          <li><a href={`/es/articles/${slug}`}>{slug.replace(/-/g, ' ')}</a></li>
        ))}
      </ul>
    </section>
  )}
</ArticleLayout>
