---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../consts';

const title = 'Privacy Policy';
const description =
  'How ITINLending.net collects, uses, and protects your information, including lead form data, analytics, cookies, and advertising.';
const updated = 'June 5, 2026';
---
<BaseLayout title={title} description={description} path="/privacy">
  <section class="section">
    <div class="container narrow">
      <span class="tag">Legal</span>
      <h1 style="margin-top:10px">Privacy Policy</h1>
      <p class="byline">Last updated {updated}</p>

      <p>
        {SITE.legalName} ("we," "us," "our") respects your privacy. This policy
        explains what we collect, why, and your choices. By using this site you
        agree to this policy.
      </p>

      <h2>Information we collect</h2>
      <ul class="lead-list">
        <li>
          <strong>Information you give us.</strong> When you submit our
          qualification or contact forms, we collect details such as your name,
          email, phone number, state, and the type of financing you're seeking.
        </li>
        <li>
          <strong>Automatic information.</strong> Like most websites, we collect
          standard log and analytics data — IP address, browser type, pages
          viewed, and referring site — through tools such as Google Analytics.
        </li>
        <li>
          <strong>Cookies.</strong> We and our partners use cookies and similar
          technologies for analytics and advertising. You can control cookies
          through your browser settings.
        </li>
      </ul>

      <h2>How we use your information</h2>
      <ul class="lead-list">
        <li>To match you with third-party lenders and partners you ask to be connected with.</li>
        <li>To respond to your questions and provide customer support.</li>
        <li>To operate, measure, and improve the site.</li>
        <li>To serve relevant advertising and comply with the law.</li>
      </ul>

      <h2>Sharing your information</h2>
      <p>
        When you submit a qualification request, we share the details you provide
        with lenders or lead partners so they can contact you about financing.
        We may also share data with service providers (e.g., analytics, hosting,
        email) who act on our behalf. We do not sell your personal information for
        money. We may disclose information if required by law.
      </p>

      <h2>Advertising &amp; Google AdSense</h2>
      <p>
        We use third-party advertising, including Google AdSense. Third-party
        vendors, including Google, use cookies to serve ads based on your prior
        visits to this and other websites. Google's use of advertising cookies
        enables it and its partners to serve ads to you based on your visits. You
        can opt out of personalized advertising by visiting
        <a href="https://www.google.com/settings/ads" rel="nofollow">Google Ads Settings</a>.
      </p>

      <h2>Your choices &amp; rights</h2>
      <p>
        You can ask us to access, correct, or delete the personal information we
        hold about you, or opt out of future contact, by
        <a href={`mailto:${SITE.supportEmail}`}>contacting us</a>. Depending
        on where you live (for example, California or the EU), you may have
        additional rights under laws such as the CCPA or GDPR.
      </p>

      <h2>Data security &amp; children</h2>
      <p>
        We use reasonable safeguards to protect your information but no method of
        transmission over the internet is completely secure. This site is not
        directed to children under 18, and we do not knowingly collect data from
        them.
      </p>

      <h2>Changes &amp; contact</h2>
      <p>
        We may update this policy from time to time; the "last updated" date above
        reflects the latest version. Questions?
        <a href={`mailto:${SITE.supportEmail}`}>Email us</a>.
      </p>

      <p class="form-note">
        This template policy is provided for general use and is not legal advice.
        Have it reviewed by a qualified attorney before relying on it.
      </p>
    </div>
  </section>
</BaseLayout>
