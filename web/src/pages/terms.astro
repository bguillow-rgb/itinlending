---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../consts';

const title = 'Terms of Use';
const description =
  'The terms governing your use of ITINLending.net, including our role as an information and referral resource, disclaimers, and limitations of liability.';
const updated = 'June 5, 2026';
---
<BaseLayout title={title} description={description} path="/terms">
  <section class="section">
    <div class="container narrow">
      <span class="tag">Legal</span>
      <h1 style="margin-top:10px">Terms of Use</h1>
      <p class="byline">Last updated {updated}</p>

      <p>
        These Terms of Use govern your access to and use of {SITE.legalName} (the
        "Site"). By using the Site, you agree to these terms. If you don't agree,
        please don't use the Site.
      </p>

      <h2>Our role</h2>
      <p>
        {SITE.name} is an independent information and referral resource. We are
        <strong>not</strong> a bank, lender, mortgage broker, credit counselor,
        or financial advisor. We do not make credit decisions, set rates, approve
        applications, or originate loans. Any financing is provided by
        third-party lenders under their own terms, eligibility criteria, and
        applicable law.
      </p>

      <h2>No financial, legal, or tax advice</h2>
      <p>
        The content on this Site is for general educational purposes only and is
        not financial, legal, immigration, or tax advice. Loan availability,
        rates, down payments, and terms vary by lender and change frequently.
        Always verify details directly with a lender and consult a qualified
        professional before making decisions.
      </p>

      <h2>Lender matching &amp; third parties</h2>
      <p>
        When you submit a request, we may share your information with third-party
        lenders or partners who may contact you. We don't control and aren't
        responsible for those third parties, their products, decisions, rates, or
        how they handle your information. Links to third-party sites are provided
        for convenience and are not endorsements.
      </p>

      <h2>Accuracy &amp; availability</h2>
      <p>
        We work to keep information accurate and current but make no guarantee
        that it is complete, error-free, or up to date. We may change or remove
        content and may suspend or discontinue the Site at any time.
      </p>

      <h2>Disclaimer of warranties &amp; limitation of liability</h2>
      <p>
        The Site is provided "as is" and "as available" without warranties of any
        kind, express or implied. To the fullest extent permitted by law,
        {SITE.legalName} is not liable for any indirect, incidental, or
        consequential damages arising from your use of the Site or reliance on its
        content, or from any dealings with third-party lenders.
      </p>

      <h2>Intellectual property &amp; acceptable use</h2>
      <p>
        Content on this Site is owned by or licensed to us and may not be copied
        or republished without permission. You agree not to misuse the Site,
        attempt to disrupt it, or use it for unlawful purposes.
      </p>

      <h2>Changes &amp; contact</h2>
      <p>
        We may update these terms from time to time. Continued use after changes
        means you accept the updated terms. Questions?
        <a href={`mailto:${SITE.supportEmail}`}>Email us</a>.
      </p>

      <p class="form-note">
        This template is provided for general use and is not legal advice. Have it
        reviewed by a qualified attorney before relying on it.
      </p>
    </div>
  </section>
</BaseLayout>
