---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import CreditKarmaAd from '../components/CreditKarmaAd.astro';
import FAQ from '../components/FAQ.astro';
import LeadForm from '../components/LeadForm.astro';
import FhaPromo from '../components/FhaPromo.astro';
import { SITE, PRODUCTS } from '../consts';

// Surface the latest guides directly from the homepage (the highest-authority
// page) so interior article URLs get a strong internal link and get crawled, 
// the fix for "Discovered - currently not indexed".
const includeDrafts = import.meta.env.DEV;
const latestPosts = (
  await getCollection('articles', ({ data }) => (includeDrafts ? true : data.published))
)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);

const faqs = [
  {
    q: 'Can I get a loan with an ITIN instead of an SSN?',
    a: 'Yes. Many banks, credit unions, and non-QM lenders accept an Individual Taxpayer Identification Number (ITIN) in place of a Social Security Number for mortgages, auto loans, personal loans, business loans, and credit cards. Requirements vary by lender and product.',
  },
  {
    q: 'Do I need a green card or visa to qualify?',
    a: 'No. ITIN lending exists specifically for people without an SSN, including those without permanent residency. Lenders focus on income, down payment, and credit history rather than immigration status. Exact eligibility depends on the lender.',
  },
  {
    q: 'How much down payment do I need for an ITIN mortgage?',
    a: 'Most ITIN mortgages require 10% to 20% down. A larger down payment can offset a thin credit file and unlock better rates. Some lenders go lower for strong borrowers; the median in 2026 sits around 15%.',
  },
  {
    q: 'Will ITIN loans hurt my credit score?',
    a: 'Getting matched and comparing options on this site does not affect your credit. A lender only runs a hard credit check once you formally apply. Paying an ITIN loan on time actually helps you build U.S. credit history.',
  },
  {
    q: 'Is ITINLending.net a lender?',
    a: 'No. We are an independent information and referral resource. We publish guides and connect ITIN holders with third-party lenders. We do not make credit decisions, set rates, or originate loans.',
  },
];
---
<BaseLayout title={SITE.name} ogImage="/og/home.png">
  <!-- Hero: institutional, text-led 60/40 split with a sidebar ledger panel. -->
  <section class="institutional-hero hero--image">
    <img class="hero-bg" src="/img/family.webp" alt="A multigenerational family together at sunset" loading="eager" fetchpriority="high" decoding="async" />
    <div class="container ihero-grid">
      <div class="ihero-copy">
        <span class="eyebrow">No SSN required</span>
        <h1>Loans, mortgages &amp; credit for ITIN holders</h1>
        <p class="lede">
          Buying a home, financing a car, or building credit with an ITIN number?
          We help foreign nationals and ITIN holders compare real lenders and
          financing options across the U.S., in plain English.
        </p>
        <div class="hero-cta">
          <a href="#lead" class="btn btn-primary btn-lg">See if you qualify</a>
          <a href="/itin-loans" class="btn btn-secondary btn-lg">How ITIN loans work</a>
        </div>
        <div class="hero-trust">
          <span><span class="check">&#10003;</span> No SSN needed</span>
          <span><span class="check">&#10003;</span> No impact to credit to check</span>
          <span><span class="check">&#10003;</span> All 50 states</span>
        </div>
      </div>
      <div class="ihero-form" id="lead">
        <LeadForm compact heading="See if you qualify — free" />
      </div>
    </div>
  </section>

  <!-- FHA-for-ITIN partner promo. Primary CTA jumps to the hero form (#lead). -->
  <FhaPromo href="#lead" />

  <!-- Below-the-fold partner unit: relocated from the hero so the homepage leads
       with value, not an ad. Labeled "Advertisement" inside the component. -->
  <section class="section-tight">
    <div class="container narrow" style="text-align:center">
      <CreditKarmaAd creativeId="3641184" cta="See how much you qualify for here" alt="Credit Karma, all things finance at your fingertips" inline={true} />
    </div>
  </section>

  <!-- Products -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>What can you finance with an ITIN?</h2>
        <p>An ITIN opens the door to most major U.S. credit products. Pick a path to see lenders, requirements, and how to qualify.</p>
      </div>
      <div class="card-grid">
        {PRODUCTS.map((p) => (
          <a class="card" href={`/${p.slug}`}>
            <div class="card-icon"><Icon name={p.icon} size={28} /></div>
            <h3>{p.label}</h3>
            <p>{p.blurb}</p>
            <span class="arrow">Learn more &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section section-surface">
    <div class="container">
      <div class="section-head">
        <h2>How it works</h2>
        <p>Three steps from "Can I even qualify?" to a real conversation with a lender.</p>
      </div>
      <div class="steps">
        <div class="step">
          <div class="num">1</div>
          <h3>Tell us what you need</h3>
          <p>Answer a few quick questions about the financing you're after and your state. Takes under a minute, no SSN, no credit pull.</p>
        </div>
        <div class="step">
          <div class="num">2</div>
          <h3>Get matched</h3>
          <p>We connect you with ITIN-friendly lenders that fit your situation, so you're not cold-calling banks that will just say no.</p>
        </div>
        <div class="step">
          <div class="num">3</div>
          <h3>Compare &amp; decide</h3>
          <p>Review rates and terms, ask questions, and move forward only when it's right for you. You're never obligated.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats / trust -->
  <section class="section-tight">
    <div class="container">
      <div class="stats">
        <div class="stat"><div class="big">5.8M+</div><div class="lbl">ITINs issued by the IRS</div></div>
        <div class="stat"><div class="big">50</div><div class="lbl">States we cover</div></div>
        <div class="stat"><div class="big">10-20%</div><div class="lbl">Typical mortgage down payment</div></div>
        <div class="stat"><div class="big">$0</div><div class="lbl">Cost to check your options</div></div>
      </div>
    </div>
  </section>

  <!-- Latest guides -->
  {latestPosts.length > 0 && (
    <section class="section section-surface">
      <div class="container narrow">
        <div class="section-head">
          <h2>Latest ITIN lending guides</h2>
          <p>Plain-English walkthroughs for financing a home, car, or business with an ITIN.</p>
        </div>
        <div class="post-list">
          {latestPosts.map((post) => (
            <a class="post-card" href={`/articles/${post.slug}`}>
              <div>
                <span class="meta">{post.data.category}</span>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
              </div>
              <span class="tag">{post.data.tier}</span>
            </a>
          ))}
        </div>
        <p style="margin-top:18px"><a href="/articles">View all ITIN lending guides &rarr;</a></p>
      </div>
    </section>
  )}

  <!-- CTA band -->
  <section class="section">
    <div class="container">
      <div class="cta-band">
        <h2>Your ITIN is enough to start.</h2>
        <p>Thousands of ITIN holders finance homes, cars, and businesses every year. See what you qualify for, it's free and it won't touch your credit.</p>
        <a href="/apply" class="btn btn-primary btn-lg">See if you qualify</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section-surface">
    <div class="container narrow">
      <FAQ faqs={faqs} heading="ITIN lending: common questions" />
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero sidebar ledger: a solid paper card over the dark photo hero, with a
     gold masthead rule. Distinct from the sister sites' translucent panels. */
  .ihero-aside {
    background: #fff;
    border: 1px solid var(--border-strong, #C2CBDB);
    border-top: 3px solid var(--accent, #B07A1E);
    border-radius: var(--radius, 3px);
    padding: 22px 24px 20px;
  }
  .ihero-aside-head {
    margin: 0 0 14px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border, #D8DFEA);
    font-family: var(--font-head, Georgia, serif);
    font-weight: 700;
    font-size: 1.02rem;
    color: var(--primary-dark, #0A1F44);
  }
  .ihero-aside-list {
    list-style: none;
    margin: 0 0 18px;
    padding: 0;
    display: grid;
    gap: 0;
  }
  .ihero-aside-list li {
    font-size: 0.93rem;
    line-height: 1.5;
    color: var(--muted, #56627A);
    padding: 11px 0;
    border-bottom: 1px solid var(--border, #D8DFEA);
  }
  .ihero-aside-list li:last-child { border-bottom: 0; }
  .ihero-aside-list strong { color: var(--text, #10192B); display: block; }
  .ihero-aside-note {
    margin: 14px 0 0;
    font-size: 0.82rem;
    color: var(--muted, #56627A);
  }
</style>
