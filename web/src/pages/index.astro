---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import LeadForm from '../components/LeadForm.astro';
import FAQ from '../components/FAQ.astro';
import { SITE, PRODUCTS } from '../consts';

const faqs = [
  {
    q: 'Can I get a loan with an ITIN instead of an SSN?',
    a: 'Yes. Many banks, credit unions, and non-QM lenders accept an Individual Taxpayer Identification Number (ITIN) in place of a Social Security Number for mortgages, auto loans, personal loans, business loans, and credit cards. Requirements vary by lender and product.',
  },
  {
    q: 'Do I need a green card or visa to qualify?',
    a: 'No. ITIN lending exists specifically for people without an SSN, including those without permanent residency. Lenders focus on income, down payment, and credit history rather than immigration status. Exact eligibility depends on the lender.',
  },
  {
    q: 'How much down payment do I need for an ITIN mortgage?',
    a: 'Most ITIN mortgages require 10% to 20% down. A larger down payment can offset a thin credit file and unlock better rates. Some lenders go lower for strong borrowers; the median in 2026 sits around 15%.',
  },
  {
    q: 'Will ITIN loans hurt my credit score?',
    a: 'Getting matched and comparing options on this site does not affect your credit. A lender only runs a hard credit check once you formally apply. Paying an ITIN loan on time actually helps you build U.S. credit history.',
  },
  {
    q: 'Is ITINLending.net a lender?',
    a: 'No. We are an independent information and referral resource. We publish guides and connect ITIN holders with third-party lenders. We do not make credit decisions, set rates, or originate loans.',
  },
];
---
<BaseLayout title={SITE.name}>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <span class="eyebrow">No SSN required</span>
        <h1>Loans, mortgages &amp; credit for ITIN holders</h1>
        <p class="lede">
          Buying a home, financing a car, or building credit with an ITIN number?
          We help foreign nationals and ITIN holders compare real lenders and
          financing options across the U.S. — in plain English.
        </p>
        <div class="hero-cta">
          <a href="/apply" class="btn btn-primary btn-lg">See if you qualify</a>
          <a href="/itin-loans" class="btn btn-secondary btn-lg">How ITIN loans work</a>
        </div>
        <div class="hero-trust">
          <span><span class="check">&#10003;</span> No SSN needed</span>
          <span><span class="check">&#10003;</span> No impact to credit to check</span>
          <span><span class="check">&#10003;</span> All 50 states</span>
        </div>
      </div>
      <div>
        <LeadForm heading="Check your options in 60 seconds" compact={true} />
      </div>
    </div>
  </section>

  <!-- Products -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>What can you finance with an ITIN?</h2>
        <p>An ITIN opens the door to most major U.S. credit products. Pick a path to see lenders, requirements, and how to qualify.</p>
      </div>
      <div class="card-grid">
        {PRODUCTS.map((p) => (
          <a class="card" href={`/${p.slug}`}>
            <div class="card-icon"><Icon name={p.icon} /></div>
            <h3>{p.label}</h3>
            <p>{p.blurb}</p>
            <span class="arrow">Learn more &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section section-surface">
    <div class="container">
      <div class="section-head">
        <h2>How it works</h2>
        <p>Three steps from "Can I even qualify?" to a real conversation with a lender.</p>
      </div>
      <div class="steps">
        <div class="step">
          <div class="num">1</div>
          <h3>Tell us what you need</h3>
          <p>Answer a few quick questions about the financing you're after and your state. Takes under a minute — no SSN, no credit pull.</p>
        </div>
        <div class="step">
          <div class="num">2</div>
          <h3>Get matched</h3>
          <p>We connect you with ITIN-friendly lenders that fit your situation, so you're not cold-calling banks that will just say no.</p>
        </div>
        <div class="step">
          <div class="num">3</div>
          <h3>Compare &amp; decide</h3>
          <p>Review rates and terms, ask questions, and move forward only when it's right for you. You're never obligated.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats / trust -->
  <section class="section-tight">
    <div class="container">
      <div class="stats">
        <div class="stat"><div class="big">5.8M+</div><div class="lbl">ITINs issued by the IRS</div></div>
        <div class="stat"><div class="big">50</div><div class="lbl">States we cover</div></div>
        <div class="stat"><div class="big">10–20%</div><div class="lbl">Typical mortgage down payment</div></div>
        <div class="stat"><div class="big">$0</div><div class="lbl">Cost to check your options</div></div>
      </div>
    </div>
  </section>

  <!-- CTA band -->
  <section class="section">
    <div class="container">
      <div class="cta-band">
        <h2>Your ITIN is enough to start.</h2>
        <p>Thousands of ITIN holders finance homes, cars, and businesses every year. See what you qualify for — it's free and it won't touch your credit.</p>
        <a href="/apply" class="btn btn-primary btn-lg">See if you qualify</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section-surface">
    <div class="container narrow">
      <FAQ faqs={faqs} heading="ITIN lending: common questions" />
    </div>
  </section>
</BaseLayout>
