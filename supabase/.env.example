# Lead Intelligence — Edge Function secrets (set with: supabase secrets set --env-file supabase/.env)
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected automatically by Supabase.

# Internal notification email (Resend). LEAD_EMAIL_TO may be comma-separated.
RESEND_API_KEY=
LEAD_EMAIL_FROM=leads@itinlending.net
LEAD_EMAIL_TO=you@example.com

# LLM executive summary (optional — if unset, the deterministic template is used).
ANTHROPIC_API_KEY=
LEAD_LLM_MODEL=claude-haiku-4-5-20251001

# CORS allow-list (defaults cover all three ITIN sites + localhost if unset).
ALLOWED_ORIGINS=https://itinlending.net,https://www.itinlending.net,https://itincreditcard.com,https://www.itincreditcard.com,https://itincreditscore.com,https://www.itincreditscore.com,http://localhost:4321

# ---------------------------------------------------------------------------
# Lead delivery to lender partners (see _shared/partners.ts + delivery.ts).
# DORMANT unless the master switch AND a partner's own switch are BOTH "true".
# With everything unset, no lead is ever sent anywhere.
# ---------------------------------------------------------------------------
# Master kill switch. Must be exactly "true" for ANY partner delivery to run.
LEAD_DELIVERY_ENABLED=false

# Engine by MoneyLion (API). Needs the key from your approved partner account.
# Also gated on certified consent: a lead only sends once the TrustedForm/Jornaya
# token is present on it (add those scripts before flipping ENGINE_ENABLED on).
ENGINE_ENABLED=false
ENGINE_API_KEY=
ENGINE_API_URL=https://api.engine.tech/v2/leads   # confirm against Engine partner docs on approval

# RGR Marketing (ping-post, mortgage/auto). Ping first, then post to claim a bid.
RGR_ENABLED=false
RGR_API_KEY=
RGR_PING_URL=
RGR_POST_URL=

# Apoyo Financiero (email warm-forward, personal). Set the intake email only
# AFTER a lead-buying agreement exists — this emails borrower info to them.
APOYO_ENABLED=false
APOYO_EMAIL=
